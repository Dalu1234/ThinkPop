# Copy to .env and paste your key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Real-time voice agent (ConvAI): create an agent at https://elevenlabs.io/agents — copy its ID
VITE_ELEVENLABS_AGENT_ID=

# Optional: override the in-app system prompt for the voice agent (otherwise a default tutor prompt is used)
# VITE_ELEVENLABS_AGENT_PROMPT=You are a helpful tutor. Ask clarifying questions when the user is vague.
# VITE_ELEVENLABS_AGENT_LANGUAGE=en

# Optional TTS/STT for the text chat path (separate from ConvAI):
# VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# VITE_ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
# VITE_ELEVENLABS_STT_MODEL=scribe_v2
