# ElevenLabs — copy to .env (see https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=

# Optional TTS/STT settings for the API-key-based voice flow:
# VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# VITE_ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
# VITE_ELEVENLABS_STT_MODEL=scribe_v2

# OpenAI — required for live multi-agent lesson generation (optional: app can use demo without it)
OPENAI_API_KEY=

# Optional overrides
OPENAI_MODEL=gpt-4o-mini

# Standalone API server only (npm run dev:api). Default dev is Vite on 127.0.0.1:5173.
LESSON_SERVER_PORT=8787

# --- Real MDM (brainpop backend) ---------------------------------------------
# Brainpop exposes POST /generate (same as ThinkPop expects). Default brainpop port is 8000,
# but ThinkPop’s motion gateway also uses 8000 — run brainpop on 8001, e.g.:
#   cd ../brainpop/backend && python -m uvicorn main:app --host 127.0.0.1 --port 8001
#
# Option A — simplest: proxy /api/motion straight to brainpop (do NOT run npm run dev:motion):
# VITE_MOTION_PROXY_TARGET=http://127.0.0.1:8001
#
# Option B — keep ThinkPop motion-server on :8000 forwarding to brainpop: copy motion-server/.env.example
# to motion-server/.env (MDM_SERVICE_URL + MOTION_DEV_STUB=0), then npm run dev:full
#
# Optional: allow in-browser procedural fallback if the motion API fails (dev only):
# VITE_MOTION_CLIENT_STUB=true
